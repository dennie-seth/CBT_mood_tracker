# --- Telegram ---
BOT_TOKEN=123456:replace-me

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Access control ---
# Comma-separated Telegram user IDs that may use this bot.
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_TELEGRAM_IDS=11111111,22222222

# --- Encryption ---
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separated list supports rotation: first key encrypts new data,
# all keys are tried on decrypt.
FERNET_KEYS=replace-with-generated-key

# --- Database ---
POSTGRES_USER=mood
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mood
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_URL=postgresql+asyncpg://mood:change-me@postgres:5432/mood

# --- Misc ---
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC
AI_MAX_TOOL_ITERATIONS=8
